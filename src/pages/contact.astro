---
import Layout from "../layouts/Layout.astro";
import Form from "../components/Form.astro";
import Field from "../components/Field.astro";
import Button from "../components/Button.astro";
import SectionMain from "../components/SectionMain.astro";
// The form POSTs to a Cloudflare Pages Function (functions/api/contact.ts),
// which runs server-side next to the static assets — no Astro adapter, so the
// site keeps build-time image optimization. (Email isn't wired up yet; the
// function validates + returns success. See that file to connect email.)
const contactUrl = "/api/contact";
---

<Layout title="Contact">
  <main id="main">
    <SectionMain id="contact" contentClass="max-w-md mx-auto">
      <header class="mb-6">
        <h1 class="h2">Get in touch</h1>
        <p class="mt-2 text-fg-muted">
          Drop your details and we'll be in touch shortly.
        </p>
      </header>

      <Form action={contactUrl} method="POST">
        <Field
          name="firstName"
          label="First name"
          type="text"
          required
          autocomplete="given-name"
          maxlength={100}
        />
        <Field
          name="lastName"
          label="Last name"
          type="text"
          required
          autocomplete="family-name"
          maxlength={100}
        />
        <Field
          name="email"
          label="Email"
          type="email"
          required
          autocomplete="email"
          maxlength={254}
        />

        <Button type="submit" variant="primary" withArrow={false}>
          Send
        </Button>

        <p slot="success">Thanks — we'll be in touch shortly.</p>
        <p slot="error">Something went wrong. Please try again.</p>
      </Form>
    </SectionMain>
  </main>
</Layout>
