# HTTP headers — same format on Cloudflare Pages and Netlify.
# Path patterns, two-space-indented header lines under each.

# Hashed build assets: filenames change when content changes, so cache forever.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Fonts (also content-hashed by the build).
/*.woff2
  Cache-Control: public, max-age=31536000, immutable

# Baseline security headers for every route.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: geolocation=(), camera=(), microphone=()
  # Content-Security-Policy is intentionally NOT set by default: this site inlines
  # CSS (inlineStylesheets:'always') and uses inline module scripts, so a strict
  # CSP needs per-build hashes/nonces. Add a tuned policy per project, e.g.:
  # Content-Security-Policy: default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'
